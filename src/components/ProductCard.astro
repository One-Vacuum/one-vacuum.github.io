---
import { ui } from '../i18n/ui';

interface Props {
  partNumber: string;
  nameKo: string;
  nameEn: string;
  image: string;
  price: string;
  rawPrice: number;
  category: string;
  descriptionKo?: string;
  descriptionEn?: string;
  bestSeller?: boolean;
  naverUrl?: string;
  coupangUrl?: string;
  /** True when `coupangUrl` is an exact product page; false when it is a
   *  generated Coupang search link. Drives the Coupang button's aria-label. */
  coupangIsExact?: boolean;
}

const { partNumber, nameKo, nameEn, image, price, rawPrice, category, descriptionKo, descriptionEn, bestSeller, naverUrl, coupangUrl, coupangIsExact } = Astro.props;

const t = ui.ko;
const coupangLabel = coupangIsExact ? t['products.viewOnCoupangExact'] : t['products.viewOnCoupang'];
---

<div
  class:list={[
    'product-card group/card h-full flex flex-col bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm border border-gray-100 dark:border-gray-700 transition-all duration-300 hover:shadow-lg hover:-translate-y-1',
    bestSeller && 'ring-2 ring-primary-400/50 dark:ring-primary-500/40',
  ]}
  data-category={category}
  data-price={rawPrice}
  data-best-seller={bestSeller ? '1' : '0'}
  data-part-number={partNumber}
>
  {bestSeller ? (
    <div class="bg-primary-500 text-white text-xs font-bold px-3 py-1 text-center" data-i18n="products.bestSeller">BEST</div>
  ) : (
    <div class="text-xs font-bold px-3 py-1">&nbsp;</div>
  )}

  <div class="aspect-square overflow-hidden bg-gray-50 dark:bg-gray-900">
    <img
      src={image}
      alt={nameKo}
      class="w-full h-full object-contain transition-transform duration-300 group-hover/card:scale-105"
      onload="this.loading='eager';if(this.naturalWidth>this.naturalHeight*1.2&&this.naturalWidth<=this.naturalHeight*2){this.classList.remove('object-contain');this.classList.add('object-cover')}"
      onerror="this.src='/images/placeholder-product.svg'"
      loading="lazy"
      decoding="sync"
    />
  </div>

  <div class="p-4 flex flex-col flex-1">
    <p class="text-xs text-gray-400 dark:text-gray-500 mb-0.5">{partNumber}</p>
    <h3 class="product-name font-semibold text-gray-900 dark:text-gray-100 text-base min-h-[2.5rem] line-clamp-2" data-name-ko={nameKo} data-name-en={nameEn}>{nameKo}</h3>
    {(descriptionKo || descriptionEn) && (
      <p class="product-desc mt-1 text-sm text-gray-500 dark:text-gray-400" data-desc-ko={descriptionKo || ''} data-desc-en={descriptionEn || ''}>{descriptionKo}</p>
    )}
    <p class="mt-2 text-lg font-bold text-primary-600 dark:text-primary-400">{price}</p>

    <!-- Store links. Coupang is always present (exact URL or generated search
         link); Naver only when the product has a listing. Buttons stack on very
         narrow cards (2-col mobile grid) and sit side by side once there's room. -->
    <div class="mt-auto pt-3 flex flex-col min-[480px]:flex-row gap-2">
      {naverUrl && (
        <a
          href={naverUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t['products.viewOnNaver']}
          class="flex-1 inline-flex items-center justify-center gap-1.5 px-2 py-2 rounded-lg bg-[#00853B] text-white text-xs font-semibold whitespace-nowrap hover:bg-[#017A36] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#00853B] focus-visible:ring-offset-2 dark:focus-visible:ring-offset-gray-800 transition-colors"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span data-i18n="products.cardNaver">{t['products.cardNaver']}</span>
        </a>
      )}
      {coupangUrl && (
        <a
          href={coupangUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={coupangLabel}
          class="flex-1 inline-flex items-center justify-center gap-1.5 px-2 py-2 rounded-lg bg-[#346AFF] text-white text-xs font-semibold whitespace-nowrap hover:bg-[#2b5ae0] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#346AFF] focus-visible:ring-offset-2 dark:focus-visible:ring-offset-gray-800 transition-colors"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span data-i18n="products.cardCoupang">{t['products.cardCoupang']}</span>
        </a>
      )}
    </div>
  </div>
</div>

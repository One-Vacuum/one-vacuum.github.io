---
interface Props {
  nameKo: string;
  nameEn: string;
  image: string;
  price: string;
  category: string;
  descriptionKo?: string;
  descriptionEn?: string;
}

const { nameKo, nameEn, image, price, category, descriptionKo, descriptionEn } = Astro.props;
---

<div class="product-card group bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 border border-gray-100 dark:border-gray-700" data-category={category}>
  <div class="aspect-square overflow-hidden bg-gray-50 dark:bg-gray-900">
    <img
      src={image}
      alt={nameKo}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      onerror="this.src='/images/placeholder-product.svg'"
      loading="lazy"
    />
  </div>
  <div class="p-4">
    <h3 class="product-name font-semibold text-gray-900 dark:text-gray-100 text-base" data-name-ko={nameKo} data-name-en={nameEn}>{nameKo}</h3>
    {(descriptionKo || descriptionEn) && (
      <p class="product-desc mt-1 text-sm text-gray-500 dark:text-gray-400" data-desc-ko={descriptionKo || ''} data-desc-en={descriptionEn || ''}>{descriptionKo}</p>
    )}
    <p class="mt-2 text-lg font-bold text-primary-600 dark:text-primary-400">{price}</p>
  </div>
</div>
